<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_pricelist_view_inherit" model="ir.ui.view">
        <field name="name">product.pricelist.form.inherit.restrict</field>
        <field name="model">product.pricelist</field>
        <field name="inherit_id" ref="product.product_pricelist_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='pricelist_rules']" position="after">
                <page name="allowed_partners" string="Restricción de Contactos">
                    <group>
                        <field name="restrict_to_contacts"/>
                    </group>
                    <group string="Contactos Permitidos" invisible="not restrict_to_contacts">
                        <field name="allowed_partner_ids" nolabel="1" colspan="2" placeholder="Seleccione los contactos que pueden usar esta lista de precios...">
                            <tree>
                                <field name="name"/>
                                <field name="parent_id"/>
                                <field name="email"/>
                                <field name="phone"/>
                            </tree>
                        </field>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
