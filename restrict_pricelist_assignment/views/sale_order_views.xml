<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_inherit_pricelist_restrict" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.pricelist.restrict</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='pricelist_id']" position="before">
                <field name="commercial_partner_id" invisible="1"/>
            </xpath>
            <xpath expr="//field[@name='pricelist_id']" position="attributes">
                <attribute name="domain">['|', ('restrict_to_contacts', '=', False), '|', ('allowed_partner_ids', 'in', partner_id), ('allowed_partner_ids', 'in', commercial_partner_id)]</attribute>
            </xpath>
        </field>
    </record>
</odoo>
